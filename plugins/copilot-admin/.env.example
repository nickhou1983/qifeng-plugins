# GitHub Copilot Admin Plugin — 环境变量配置
# 复制此文件为 .env 并填入实际值

# ============================================================
# GitHub Personal Access Token
# ============================================================
# Organization 模式：需要 manage_billing:copilot 或 read:org 权限
#   Fine-grained PAT 可用，需要 "GitHub Copilot Business" 或 "Administration" (read) 权限
# Enterprise 模式：需要 PAT (classic) + manage_billing:copilot 或 read:enterprise 权限
#   ⚠️ Fine-grained PAT 不支持企业级端点
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ============================================================
# 查询目标
# ============================================================
# 组织名称（用于 --scope org 模式）
GITHUB_ORG=your-org-name

# 企业 slug（用于 --scope enterprise 模式）
# 可在 https://github.com/enterprises/<slug> 中找到
GITHUB_ENTERPRISE=your-enterprise-slug

# ============================================================
# GitHub API 版本（可选，通常无需修改）
# ============================================================
# GITHUB_API_VERSION=2022-11-28
